{
    "name": "cryonighter/formula-doctrine",
    "type": "package",
    "description": "Hibernate-style attribute #[Formula] computed fields for Doctrine ORM entities",
    "homepage": "https://github.com/cryonighter/formula-doctrine",
    "license": "MIT",
    "keywords": ["doctrine", "orm", "formula", "virtual", "generated", "computed", "symfony", "hibernate"],
    "version": "1.1.4",
    "authors": [
        {
            "name": "Andrey Reshetchenko",
            "email": "cryonighter@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.2",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "symfony/cache": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "Cryonighter\\FormulaDoctrine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cryonighter\\FormulaDoctrine\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
